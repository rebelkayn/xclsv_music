generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Artist {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  email     String   @unique
  password  String
  genre     String
  tagline   String
  price     Int      @default(10000000)
  image     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Collector {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model ArtistInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  genre     String
  instagram String?
  spotify   String?
  message   String?
  createdAt DateTime @default(now())
}

model Order {
  id                String     @id @default(cuid())
  artist            Artist     @relation(fields: [artistId], references: [id])
  artistId          String
  collector         Collector? @relation(fields: [collectorId], references: [id])
  collectorId       String?
  status            String     @default("DEPOSITED")
  collectorName     String
  collectorEmail    String
  vision            String
  occasion          String
  totalPrice        Int
  depositPaid       Int       @default(0)
  balancePaid       Int       @default(0)
  audioFile         String?
  previewFile       String?
  createdAt         DateTime  @default(now())
  estimatedDelivery DateTime
  deliveredAt       DateTime?
}
